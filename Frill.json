{
    "schema": {
        "crud_objects": {
            "announcements": {
                "operations": {
                    "announcementList": {
                        "method": "get",
                        "call": {
                            "path": "/v1/announcements"
                        },
                        "processing_options": {
                            "output_field": "data"
                        }
                    }
                },
                "key": "idx",
                "resources": {
                    "name": "string*",
                    "slug": "string*",
                    "excerpt": "string*",
                    "reaction_count": "number*",
                    "published_at": "datetime*",
                    "created_at": "string*",
                    "updated_at": "string*",
                    "idx": "string*",
                    "author": {
                        "name": "string*",
                        "email": "string*",
                        "avatar": "string*",
                        "created_at": "string*",
                        "updated_at": "string*",
                        "idx": "string*"
                    },
                    "categories": [
                        {
                            "name": "string*",
                            "color": "string*",
                            "created_at": "datetime*",
                            "updated_at": "datetime*",
                            "idx": "string*"
                        }
                    ],
                    "ideas": "string*",
                    "is_published": "boolean*"
                }
            },
            "announcement_categories": {
                "operations": {
                    "announcement_categoriesList": {
