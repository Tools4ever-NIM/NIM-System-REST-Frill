                        },
                        "processing_options": {
                            "output_field": "data"
                        }
                    }
                },
                "key": "idx",
                "resources": {
                    "idx": "string*",
                    "name": "string*",
                    "color": "string*",
                    "translations": {
                        "en": {
                            "name": "_:string*"
                        }
                    },
                    "created_at": "string*",
                    "updated_at": "string*"
                }
            },
            "comments": {
                "operations": {
                    "commentsList": {
                        "method": "get",
                        "call": {
                            "mode": "iteration",
                            "table": "ideas",
                            "iterator": "idx",
                            "path": "/v1/comments",
                            "queryParameters": {
                                "idea_idx": "{iterator}"
                            },
                            "base": {
                                "idea_idx": "{iterator}"
                            }
                        },
                        "processing_options": {
                            "output_field": "data"
                        },
                        "maxSessionCount": 2
                    }
                },
                "key": "idx",
                "resources": {
                    "idx": "string*",
                    "message": "string*",
                    "content_html": "string*",
                    "content_markdown": "string*",
                    "approval_status": "string*",
                    "is_private": "boolean*",
                    "url": "string*",
                    "created_at": "string*",
                    "updated_at": "string*",
                    "idea_idx": "string*",
                    "attachments": "string*",
                    "author": {
                        "idx": "_:string*",
                        "avatar": "_:string",
                        "name": "_:string*",
                        "email": "_:string*",
                        "type": "_:string*",
                        "created_at": "_:string",
                        "updated_at": "_:string",
                        "attributes": "_:string",
                        "companies": "_:string"
                    }
                }
            },
            "followers": {
                "operations": {
                    "followersList": {
                        "method": "get",
                        "call": {
                            "path": "/v1/followers"
                        },
                        "processing_options": {
                            "output_field": "data"
                        }
                    },
                    "followerCreate": {
                        "method": "post",
                        "call": {
                            "mode": "normal",
                            "path": "/v1/followers"
                        },
                        "semantics": "create",
                        "resource_allowance_default": "optional",
                        "resource_mandatory": ["email"],
                        "resource_prohibited": [
                            "idx",
                            "type",
                            "created_at",
                            "updated_at"
                        ]
                    },
                    "followerDelete": {
                        "method": "delete",
                        "call": {
                            "mode": "normal",
                            "path": "/v1/followers/{idx}"
                        },
                        "semantics": "delete",
                        "resource_allowance_default": "prohibited",
                        "resource_mandatory": ["idx"],
                        "resource_prohibited": ["idx"]
                    }
                },
                "key": "idx",
                "resources": {
                    "idx": "string*",
                    "avatar": "string*",
                    "name": "string*",
                    "email": "string*",
                    "type": "string*",
                    "created_at": "datetime*",
                    "updated_at": "datetime*"
                }
            },
            "ideas": {
                "operations": {
                    "ideasList": {
                        "method": "get",
                        "call": {
                            "path": "/v1/ideas"
                        },
                        "processing_options": {
                            "output_field": "data"
                        }
                    }
                },
                "key": "idx",
                "resources": {
                    "slug": "string*",
                    "name": "string*",
                    "description": "string*",
                    "cover_image": "string*",
                    "vote_count": "number*",
                    "comment_count": "number*",
                    "is_private": "boolean*",
                    "is_bug": "boolean*",
                    "show_in_roadmap": "boolean*",
                    "is_archived": "boolean*",
                    "is_shortlisted": "boolean*",
                    "is_completed": "boolean*",
                    "approval_status": "string*",
                    "created_at": "datetime*",
                    "updated_at": "datetime*",
                    "excerpt": "string*",
                    "is_pinned": "boolean*",
                    "idx": "string*",
                    "author": {
                        "idx": "_:string*",
                        "avatar": "_:string*",
                        "name": "_:string*",
                        "email": "_:string*",
                        "created_at": "_:datetime*",
                        "updated_at": "_:datetime*"
                    },
                    "created_by": "string*",
                    "status": {
                        "name": "_:string*",
                        "color": "_:string*",
                        "is_completed": "boolean*",
                        "idx": "_:string*"
                    },
                    "topics": [
                        {
                            "idea_id": "_nim*",
                            "name": "string*",
                            "order": "number*",
                            "idx": "string*"
                        }
                    ]
                }
            },
            "statuses": {
                "operations": {
                    "statusesList": {
                        "method": "get",
                        "call": {
                            "path": "/v1/statuses"
                        },
                        "processing_options": {
                            "output_field": "data"
                        }
                    }
                },
                "key": "idx",
                "resources": {
                    "name": "string*",
                    "color": "string*",
                    "is_completed": "boolean*",
                    "created_at": "datetime*",
                    "updated_at": "datetime*",
                    "idx": "string*"
                }
            },
            "topics": {
                "operations": {
                    "topicsList": {
                        "method": "get",
                        "call": {
                            "path": "/v1/topics"
                        },
                        "processing_options": {
                            "output_field": "data"
                        }
                    }
                },
                "key": "idx",
                "resources": {
                    "name": "string*",
                    "is_private": "boolean*",
                    "order": "number*",
                    "created_at": "datetime*",
                    "updated_at": "datetime*",
                    "idx": "string*"
                }
            },
            "votes": {
                "operations": {
                    "votesList": {
                        "method": "get",
                        "call": {
                            "path": "/v1/votes"
                        },
                        "processing_options": {
                            "output_field": "data"
                        }
                    }
                },
                "key": "idx",
                "resources": {
                    "created_at": "datetime*",
                    "updated_at": "datetime*",
                    "idx": "string*",
                    "idea": {
                        "slug": "string*",
                        "name": "string*",
                        "description": "string*",
                        "cover_image": "string*",
                        "vote_count": "number*",
                        "comment_count": "number*",
                        "is_private": "boolean*",
                        "is_bug": "boolean*",
                        "show_in_roadmap": "boolean*",
                        "is_archived": "boolean*",
                        "is_shortlisted": "boolean*",
                        "is_completed": "boolean*",
                        "approval_status": "string*",
                        "created_at": "datetime*",
                        "updated_at": "datetime*",
                        "excerpt": "string*",
                        "is_pinned": "boolean*",
                        "idx": "string*",
                        "author": {
                            "idx": "string*",
                            "avatar": "string*",
                            "name": "string*",
                            "email": "string*",
                            "created_at": "datetime*",
                            "updated_at": "datetime*"
                        },
                        "created_by": "string*",
                        "status": {
                            "name": "string*",
                            "color": "string*",
                            "is_completed": "boolean*",
                            "created_at": "datetime*",
                            "updated_at": "datetime*",
                            "idx": "string*"
                        },
                        "topics": [
                            {
                                "name": "string*",
                                "is_private": "boolean*",
                                "order": "number*",
                                "created_at": "datetime*",
                                "updated_at": "datetime*",
                                "idx": "string*"
                            }
                        ]
                    },
                    "voter": {
                        "idx": "string*",
                        "avatar": "string*",
                        "name": "string*",
                        "email": "string*",
                        "created_at": "datetime*",
                        "updated_at": "datetime*"
                    }
                }
            }
        }
    },
    "rest": {
        "config": {
            "baseUrl": "https://api.frill.co",
            "get": {
                "maxPageCount": 500,
                "query_parameters": {
                    "limit": "{page_size}"
                },
                "pagination": {
                    "mode": "url",
                    "replace_in_url": true,
                    "last_page": {
                        "type": "token",
                        "path": "pagination.endCursor"
                    },
                    "query_params": [
                        {
                            "name": "after",
                            "value": {
                                "type": "response_field",
                                "value": "pagination.endCursor"
                            }
                        }
                    ]
                }
            },
            "authentication": "aeries",
            "call_handling": "generic",
            "retry": [
                {
                    "type": "statusCode",
                    "statusCode": 429,
                    "retry": {
                        "type": "simple",
                        "maxCount": 12,
                        "waitTime": 5
                    }
                },
                {
                    "type": "connectionError"
                }
            ],
            "test_connection": {
                "url": "/v1/ideas"
            },
            "accept": "application/json",
            "headers": {
                "Authorization": "Bearer {client_secret}"
            }
        }
    },
    "connection": {
        "items": [
            {
                "name": "page_size",
                "type": "textbox",
                "label": "Page Size:",
                "value": "100",
                "required": true
            }
        ]
    }
}
